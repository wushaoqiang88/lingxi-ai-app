# 选择供应商：deepseek / qwen / glm / kimi / siliconflow / openai / custom
AI_PROVIDER=deepseek

# 通用 OpenAI 兼容配置。优先级高于内置供应商配置。
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_TEMPERATURE=0.75
AI_TIMEOUT_SECONDS=60

# 可选：分别配置多个供应商，后端会按 AI_PROVIDER 读取。
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
SILICONFLOW_API_KEY=
OPENAI_API_KEY=

# 可选模型覆盖
DEEPSEEK_MODEL=deepseek-chat
QWEN_MODEL=qwen-plus
GLM_MODEL=glm-4-flash
KIMI_MODEL=moonshot-v1-8k
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
OPENAI_MODEL=gpt-4o-mini
